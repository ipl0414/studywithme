# Text generation
TEXT_API_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_THINKING_LEVEL=minimal
GEMMA_TEXT_MODEL=gemma-4-31b-it

# Image generation
IMAGE_API_PROVIDER=gemini
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_GROUNDING=off
VISUAL_NOVEL_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_INPUT_FIDELITY=high

# Set to yes when collaborators want to run the app without image API calls.
TEST_NO_IMAGE=yes

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_DAILY_CHAT_MODEL=gpt-5.2
OPENAI_PREMIUM_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_TEXT_TIMEOUT=180
OPENAI_IMAGE_TIMEOUT=180

# Optional local LM Studio fallback
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234
LOCAL_LLM_MODEL=gemma-4-e4b
LOCAL_LLM_DISABLE_REASONING=yes
LOCAL_LLM_MIN_OUTPUT_TOKENS=1024

# Future persistence integrations
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/study_app
OBJECT_STORAGE_BUCKET=
